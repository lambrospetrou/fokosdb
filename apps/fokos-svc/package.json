{
	"name": "fokos-svc",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"check": "tsc --noEmit",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "npm run check && vitest run",
		"test:hurl": "hurl --variables-file test/hurl/vars.env --test --report-json test/hurl/report-json --connect-timeout 2 test/hurl/*.hurl",
		"test:hurl:run": "hurl --variables-file test/hurl/vars.env --test --report-json test/hurl/report-json --connect-timeout 2",
		"pre:test:hurl:remote": "rm -rf test/hurl/report-json && mkdir -p test/hurl/report-json",
		"test:hurl:remote": "hurl --variables-file test/hurl/vars_remote.env --test --report-json test/hurl/report-json --connect-timeout 2",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.15.2",
		"@types/node": "^25.6.0",
		"durable-utils": "^0.3.5",
		"hono": "^4.12.22",
		"js-xxhash": "^5.0.1",
		"typescript": "^5.9.3",
		"valibot": "^1.4.0",
		"vitest": "^4.1.5",
		"wrangler": "^4.94.0"
	}
}
